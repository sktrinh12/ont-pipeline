/*
========================================================================================
    NEXTFLOW CONFIGURATION — ONT-WGS & Methylation Pipeline
========================================================================================
*/

manifest {
    name            = 'ont-wgs-methylation-pipeline'
    version         = '1.0.0'
    description     = 'ONT long-read WGS pipeline: SV calling, 5mC methylation, pangenome'
    author          = 'ONT Genomics'
    nextflowVersion = '>=25.04.0'
    mainScript      = 'main.nf'
}

// ── Global default parameters ────────────────────────────────────────────────
params {

    // Input/Output
    input               = null       // Path to samplesheet CSV
    input_dir           = null       // OR directory of pod5/fast5/fastq files
    outdir              = 'results'

    // References (required)
    reference           = null       // T2T-CHM13v2.0 FASTA (.fa or .fa.gz)
    reference_fai       = null       // Samtools .fai index

    // Optional references
    tandem_repeats      = null       // BED file for Sniffles2 SV annotation (highly recommended)
    dbsnp_vcf           = null       // dbSNP VCF for Clair3 annotation
    pangenome_gbz       = null       // HPRC v1.1 GBZ graph (enables vg giraffe step)
    pangenome_min_index = null       // Corresponding .min index
    pangenome_dist      = null       // Corresponding .dist index
    pangenome_zipcode   = null       // Corresponding .zip zipcode index
    odgi_region         = null       // Set to "PATH:start-end" to restrict viz (e.g., "chr22:0-51324926")

    // Basecalling (Dorado)
    skip_basecalling    = false      // Set true if providing pre-basecalled FASTQ
    dorado_model        = 'dna_r10.4.1_e8.2_400bps_sup@v4.3.0' // SUP model (best accuracy)
    duplex              = false      // Enable Dorado duplex (requires paired pod5 reads)
    dorado_min_qscore   = 10        // Minimum Q-score filter at basecalling stage

    // Read filtering (post-basecalling, pre-alignment)
    min_read_length     = 1000       // bp — removes chimeric ultra-short reads
    min_read_quality    = 10         // Q-score cutoff for Chopper
    max_read_length     = 0          // 0 = no upper limit

    // Alignment (minimap2)
    minimap2_preset     = 'lr:hq'   // ONT R10 high-quality preset (replaces older 'map-ont')
    sort_bam            = true
    markdup             = true       // Mark optical/PCR duplicates

    // Coverage QC gate — pipeline halts sample if coverage is below threshold
    min_coverage        = 15         // X coverage (mosdepth)
    skip_coverage_gate = false      // Bypass coverage gate (for testing/pre-QC'd data)

    // Methylation (modkit)
    skip_methylation    = true
    modkit_motifs       = 'CpG 0'   // Primary motif; add 'CHH 0 CHG 0' for plant/cancer
    methylation_cpg_only = true      // Filter to CpG context only
    cpg_islands_bed    = null        // Optional: CpG islands BED for annotation

    // Variant calling
    clair3_model        = null       // Auto-detected from dorado_model if null
    clair3_min_coverage = 4
    sniffles_min_support = 5         // Min reads supporting SV
    sniffles_min_svlen  = 50         // Min SV length in bp

    // Phasing
    skip_phasing        = false      // longphase + haplotagging
    longphase_threads   = 8

    // Pangenome (vg giraffe)
    vg_threads          = 16

    // MultiQC
    multiqc_config      = "${projectDir}/assets/multiqc_config.yml"
    multiqc_title       = 'ONT-WGS Pipeline Report'

    // Resource limits (override per profile)
    max_cpus            = 96
    max_memory          = '400.GB'
    max_time            = '240.h'
}

// ── Process defaults ─────────────────────────────────────────────────────────
process {
    // Default: use copy to avoid symlink issues with Docker volumes
    stageInMode = 'copy'

    // Default: conservative
    cpus    = { 4 * task.attempt }
    memory  = { 8.GB * task.attempt }
    time    = { 4.h * task.attempt }

    errorStrategy = { task.exitStatus in [104, 134, 137, 139, 143, 247] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // Per-process resource overrides
    withLabel: 'process_low' {
        cpus   = { 4 * task.attempt }
        memory = { 5.GB * task.attempt }
        time   = { 2.h * task.attempt }
    }
    withLabel: 'process_medium' {
        cpus   = { 8 * task.attempt }
        memory = { 32.GB * task.attempt }
        time   = { 8.h * task.attempt }
    }
    withLabel: 'process_high' {
        cpus   = { 32 * task.attempt }
        memory = { 128.GB * task.attempt }
        time   = { 48.h * task.attempt }
    }
    withLabel: 'process_long' {
        time   = { 64.h * task.attempt }
    }
}

// ── Profiles ─────────────────────────────────────────────────────────────────
profiles {

    // ── Docker  ──────────────────────────────────────
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        conda.enabled          = false
    }

    // ── Conda  ───────────────────────────────────────
    conda {
        conda.enabled          = true
        conda.useMamba         = true   // Mamba for faster solves
        docker.enabled         = false
        singularity.enabled    = false
    }

    // ── AWS Batch ─────────────────────────────────────────────────────────────
    aws {
        process.executor       = 'awsbatch'
        process.queue          = 'ont-genomics-queue'
        aws.region             = 'us-east-1'
        aws.batch.cliPath      = '/usr/local/bin/aws'
        workDir                = 's3://bucket-name/nextflow-work'
        params {
            max_cpus   = 96
            max_memory = '384.GB'
            max_time   = '240.h'
        }
    }

    // ── Test (Chr22 HG002 subset) ───────────────────────────
    test {
        process.executor = 'local'
        process.queueSize = 1
        docker.enabled = true
        docker.runOptions = '-v /home/spencer-trinh/Downloads/ont-wgs-pipeline/data:/home/spencer-trinh/Downloads/ont-wgs-pipeline/data:ro'
        params {
            input               = "${projectDir}/test/samplesheet_test.csv"
            reference           = "${projectDir}/refs/chm13_chr22.fa"
            tandem_repeats      = "${projectDir}/refs/chm13v2.0_RepeatMasker_4.1.2p1.2022Apr14.bed"
            skip_basecalling    = true
            skip_phasing        = false
            skip_methylation    = true
            pangenome_gbz       = "${projectDir}/refs/chr22.gbz"
            pangenome_min_index = "${projectDir}/refs/chr22.min"
            pangenome_dist      = "${projectDir}/refs/chr22.dist"
            pangenome_zipcode   = "${projectDir}/refs/chr22.zip"
            odgi_region         = 'CHM13#chr22:0-*'
            min_coverage        = 1
            skip_coverage_gate  = true
            dorado_min_qscore   = 8
            max_cpus            = 4
            max_memory          = '6.GB'
            max_time            = '6.h'
            outdir              = 'test_results'
        }
    }
}

// ── Timeline, trace, and DAG reports ─────────────────────────────────────────
timeline {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/report.html"
}

trace {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    fields    = 'task_id,name,status,exit,duration,realtime,cpus,%cpu,memory,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,submit,start,complete'
}

dag {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/dag.svg"
}
